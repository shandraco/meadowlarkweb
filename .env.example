# ─── Supabase ───────────────────────────────────────────────────────────────
# Project URL + keys: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Admin key — server only, NEVER expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe (Test mode) ─────────────────────────────────────────────────────
# Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Created when you set up the webhook (Stripe CLI for local, dashboard for prod)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL for redirects (http://localhost:3000 locally; your domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
