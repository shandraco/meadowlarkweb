# ─── Supabase ───────────────────────────────────────────────────────────────
# Project URL + keys: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Admin key — server only, NEVER expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Payments ───────────────────────────────────────────────────────────────
# Which provider the checkout flow uses. To swap, add a new implementation of
# PaymentProvider in lib/payments/ and register it in provider.ts.
PAYMENT_PROVIDER=stripe

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys. Use test keys locally.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Created when you set up the webhook (Stripe CLI for local, dashboard for prod)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL for redirects (http://localhost:3000 locally; your domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Transactional email ────────────────────────────────────────────────────
# Provider abstraction lives in lib/email/. Resend is the default. Leaving
# these blank makes send helpers no-op locally without breaking the app.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxx
# Verified sending identity — Resend dashboard → Domains
EMAIL_FROM="Meadowlark Farm <hello@themeadowlarkfarm.com>"
# Where booking notifications go for the farm (leave blank to skip)
ADMIN_NOTIFICATIONS_EMAIL=gina@themeadowlarkfarm.com
